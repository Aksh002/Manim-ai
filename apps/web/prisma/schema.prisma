generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  creditBalance CreditBalance?
  creditLedger  CreditLedger[]
  llmConfigs    LlmConfig[]
  renderJobs    RenderJob[]
  benchmarks    BenchmarkRun[]
  chatSessions  ChatSession[]
  chatMessages  ChatMessage[]
  codeVersions  CodeVersion[]
  sessionRenders SessionRender[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model CreditBalance {
  userId    String   @id
  available Int      @default(0)
  reserved  Int      @default(0)
  spent     Int      @default(0)
  refunded  Int      @default(0)
  expired   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id        String   @id @default(cuid())
  userId    String
  jobId     String?
  amount    Int
  state     String
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([jobId])
}

model LlmConfig {
  id              String    @id @default(cuid())
  userId          String
  name            String
  baseUrl         String
  model           String
  encryptedApiKey String    @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
}

model RenderJob {
  id          String    @id @default(cuid())
  userId      String
  backendJobId String   @unique
  creditLedgerId String?
  status      String
  target      String?
  codeHash    String?
  chatSessionId String?
  codeVersionId String?
  sessionRenderId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([chatSessionId])
  @@index([codeVersionId])
  @@index([sessionRenderId])
}

model BenchmarkRun {
  id            String   @id @default(cuid())
  userId        String?
  prompt        String
  success       Boolean
  qualityScore  Float?
  repairAttempts Int?
  renderSeconds Float?
  artifactUrl   String?
  metadata      Json?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
model ChatSession {
  id                  String          @id @default(cuid())
  userId              String
  title               String          @default("Untitled scene")
  archived            Boolean         @default(false)
  activeCodeVersionId String?
  activeRenderId      String?
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  lastActivityAt      DateTime        @default(now())
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages            ChatMessage[]
  codeVersions        CodeVersion[]
  renders             SessionRender[]

  @@index([userId, archived, lastActivityAt])
}

model ChatMessage {
  id            String      @id @default(cuid())
  userId        String
  chatSessionId String
  role          String
  kind          String
  content       String      @db.Text
  metadata      Json?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  codeVersions  CodeVersion[]

  @@index([chatSessionId, createdAt])
  @@index([userId, createdAt])
}

model CodeVersion {
  id              String          @id @default(cuid())
  userId          String
  chatSessionId   String
  messageId       String?
  source          String
  code            String          @db.Text
  codeHash        String
  parentVersionId String?
  metadata        Json?
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSession     ChatSession     @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  message         ChatMessage?    @relation(fields: [messageId], references: [id], onDelete: SetNull)
  parentVersion   CodeVersion?    @relation("CodeVersionLineage", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions   CodeVersion[]   @relation("CodeVersionLineage")
  renders         SessionRender[]

  @@index([chatSessionId, createdAt])
  @@index([userId, createdAt])
  @@index([codeHash])
}

model SessionRender {
  id                String      @id @default(cuid())
  userId            String
  chatSessionId     String
  codeVersionId     String
  backendJobId      String?     @unique
  target            String
  quality           String
  status            String
  codeHash          String?
  videoUrl          String?
  thumbnailUrl      String?
  artifactExpiresAt DateTime?
  pinned            Boolean     @default(false)
  artifactAvailable Boolean     @default(false)
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSession       ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  codeVersion       CodeVersion @relation(fields: [codeVersionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@index([userId, createdAt])
  @@index([codeVersionId])
}


