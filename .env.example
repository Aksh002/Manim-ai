# App
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen3-coder
LLM_MAX_TOKENS=2048
LLM_STORYBOARD_MAX_TOKENS=1500
LLM_SCENE_PLAN_MAX_TOKENS=3000
LLM_CODE_MAX_TOKENS=6000
LLM_REPAIR_MAX_TOKENS=4000
LLM_SYSTEM_PROMPT=
LLM_REQUEST_TIMEOUT_SEC=120
ALLOW_LLM_FALLBACK=false
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DATABASE_PASSWORD=
INTERNAL_API_TOKEN=
ALLOW_OWNER_TOKEN_FALLBACK=true
FREE_CREDITS_ON_SIGNUP=5
BYOK_DAILY_RENDER_LIMIT=20
USER_SECRET_ENCRYPTION_KEY=
GENERATION_PIPELINE_MODE=structured
MAX_GENERATION_REPAIRS=2
PROMPT_POLICY_VERSION=2026-06-skill-guided-v1
VALIDATOR_POLICY_VERSION=2026-06-static-repair-v1
RENDERER_POLICY_VERSION=2026-06-docker-tmpfs-v1
SKILL_POLICY_VERSION=2026-06-skill-guided-v1
SKILL_CONTEXT_MAX_CHARS=6000
PLANNER_CRITIC_ENABLED=true
PLANNER_CRITIC_THRESHOLD=0.72
API_PORT=8000
WEB_PORT=3000

# Web / Auth.js
AUTH_REQUIRED=false
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
INTERNAL_API_BASE=http://api:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Redis / Queue
REDIS_URL=redis://redis:6379/0
USE_QUEUE=true

# Rendering
VIDEO_STORAGE_ROOT=/data/videos
STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
ARTIFACT_SIGNING_SECRET=
ARTIFACT_URL_TTL_SEC=900
JOB_RETENTION_HOURS=72
ARTIFACT_RETENTION_HOURS=72
CLEANUP_INTERVAL_SEC=3600
RENDER_TIMEOUT_SEC=120
MAX_RENDER_RETRIES=2
RENDER_MODE=docker
RENDERER_SERVICE_URL=http://renderer:8100
DEFAULT_RENDER_QUALITY=1080p30
PREVIEW_RENDER_QUALITY=480p15

# Sandbox limits
RENDERER_IMAGE=manim-ai-renderer:latest
RENDERER_IMAGE_DIGEST=
MANIM_VERSION=0.20.1
SANDBOX_CPU=1.0
SANDBOX_MEMORY=1g
SANDBOX_PIDS_LIMIT=256
SANDBOX_READ_ONLY=true
SANDBOX_NETWORK_DISABLED=true
SANDBOX_NO_NEW_PRIVILEGES=true
SANDBOX_SECCOMP_PROFILE=

# API
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MIN=60
TRUST_PROXY_HEADERS=false

